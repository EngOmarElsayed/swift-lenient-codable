"generated":true}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MarkerMacro","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The annotations exist so that "},{"type":"codeVoice","code":"@LenientDecodable"},{"type":"text","text":" can "},{"type":"emphasis","inlineContent":[{"text":"read them off the","type":"text"},{"text":" ","type":"text"},{"text":"attribute list","type":"text"}]},{"text":" during its own expansion (via ","type":"text"},{"type":"codeVoice","code":"MarkerAnnotation"},{"type":"text","text":") — they"},{"type":"text","text":" "},{"type":"text","text":"carry information, not behavior. But an attached macro must be backed by"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"some","type":"text"}]},{"text":" implementation for the attribute to be legal Swift, so all three","type":"text"},{"type":"text","text":" "},{"type":"text","text":"declarations in the "},{"type":"codeVoice","code":"LenientCodable"},{"type":"text","text":" module point here, and the expansion"},{"type":"text","text":" "},{"type":"text","text":"intentionally returns nothing."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A peer macro is the least invasive attachment role for this job: it adds","type":"text"},{"text":" ","type":"text"},{"text":"no members, no accessors, and no conformances, so the annotated property","type":"text"},{"text":" ","type":"text"},{"text":"stays a plain stored property — ","type":"text"},{"code":"Equatable","type":"codeVoice"},{"text":"\/","type":"text"},{"code":"Hashable","type":"codeVoice"},{"text":"\/memberwise-init","type":"text"},{"text":" ","type":"text"},{"text":"synthesis keep working, and there is zero runtime footprint. (Compare a","type":"text"},{"text":" ","type":"text"},{"text":"property-wrapper approach, which would change the stored type itself.)","type":"text"}]},{"inlineContent":[{"type":"text","text":"Validation is "},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"text":" done here, by design: this macro expands once per","type":"text"},{"type":"text","text":" "},{"type":"text","text":"annotation in isolation, with no view of the property’s declared shape or"},{"type":"text","text":" "},{"type":"text","text":"competing annotations. All rules about where an annotation may appear"},{"type":"text","text":" "},{"type":"text","text":"live in "},{"type":"codeVoice","code":"LenientDecodableMacro.resolveStrategies"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"validateShapes"},{"type":"text","text":", which"},{"type":"text","text":" "},{"type":"text","text":"see the whole struct at once."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/lenientcodablemacros\/markermacro"]}],"references":{"doc://LenientCodableMacros/documentation/LenientCodableMacros/MarkerMacro/Macro-Implementations":{"url":"\/documentation\/lenientcodablemacros\/markermacro\/macro-implementations","type":"topic","role":"collectionGroup","title":"Macro Implementations","abstract":[],"kind":"article","identifier":"doc:\/\/LenientCodableMacros\/documentation\/LenientCodableMacros\/MarkerMacro\/Macro-Implementations"},"doc://LenientCodableMacros/documentation/LenientCodableMacros":{"kind":"symbol","url":"\/documentation\/lenientcodablemacros","role":"collection","type":"topic","identifier":"doc:\/\/LenientCodableMacros\/documentation\/LenientCodableMacros","title":"LenientCodableMacros","abstract":[]},"doc://LenientCodableMacros/17SwiftSyntaxMacros5MacroP":{"type":"unresolvable","identifier":"doc:\/\/LenientCodableMacros\/17SwiftSyntaxMacros5MacroP","title":"SwiftSyntaxMacros.Macro"},"doc://LenientCodableMacros/s16SendableMetatypeP":{"type":"unresolvable","i